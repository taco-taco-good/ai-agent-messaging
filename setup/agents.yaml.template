agents:
  # 내부에서 안정적으로 사용하는 에이전트 식별자입니다. slug 형태를 권장하며, 세션/로그/메모리 경로의 기준이 됩니다.
  <agent-name>:
    # Discord와 로그에 표시되는 사람이 읽기 쉬운 이름입니다.
    display_name: <Agent Display Name>

    # 사용할 CLI 제공자 종류입니다. 지원 값: claude, codex, gemini
    provider: <provider>

    # 이 에이전트의 Discord 봇 토큰입니다.
    discord_token: <DISCORD_BOT_TOKEN>

    # 제공자 시작 시 사용할 기본 모델입니다.
    model: <default-model>

    # 페르소나 마크다운 파일 경로입니다. `./setup/init.sh`가 `config/personas/` 디렉터리를 만들어줍니다.
    persona_file: ./personas/<agent-name>.md

    # 실제 CLI가 실행되는 작업 디렉터리이며, 제공자별 초기 문서도 여기에 생성됩니다.
    workspace_dir: ../workspace/<agent-name>

    # 이 에이전트의 영구 대화 메모리 저장 디렉터리입니다.
    memory_dir: ../memory/<agent-name>

    # 제공자의 기본 CLI 명령 뒤에 추가로 전달할 인자들입니다.
    cli_args:
      - <extra-cli-arg>

# 선택 사항: 백그라운드 job YAML 문서를 둘 디렉터리입니다.
jobs_dir: ../jobs

# 선택 사항: agent가 읽는 skill markdown 문서를 둘 디렉터리입니다.
skills_dir: ../skills

# 선택 사항: 외부 tool manifest와 실행 스크립트를 둘 디렉터리입니다.
tools_dir: ../tools

# 선택 사항: scheduler/job run 상태를 저장할 SQLite 경로입니다.
job_store_path: ../runtime/jobs.sqlite
